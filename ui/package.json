{
  "name": "fineliner-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "wasm": "cd ../crates/fineliner-wasm && wasm-pack build --target web --release --out-dir ../../ui/src/lib/wasm/pkg",
    "dev": "pnpm run wasm && vite",
    "build": "pnpm run wasm && vite build",
    "preview": "vite preview",
    "check": "pnpm run wasm && svelte-check --tsconfig ./tsconfig.json",
    "lint": "pnpm run check"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
